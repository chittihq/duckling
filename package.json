{
  "name": "duckling-monorepo",
  "version": "1.0.0",
  "description": "Duckling - DuckDB server with MySQL replication (monorepo)",
  "private": true,
  "scripts": {
    "build": "pnpm --filter \"./packages/**\" build",
    "build:shared": "pnpm --filter @lmes/duckling-shared build",
    "build:sdk": "pnpm --filter @lmes/duckling build",
    "build:server": "pnpm --filter @lmes/duckling-server build",
    "build:frontend": "pnpm --filter @lmes/duckling-frontend build",
    "dev": "pnpm --parallel --filter \"./packages/**\" dev",
    "dev:server": "pnpm --filter @lmes/duckling-server dev",
    "dev:frontend": "pnpm --filter @lmes/duckling-frontend dev",
    "dev:sdk": "pnpm --filter @lmes/duckling dev",
    "start:server": "pnpm --filter @lmes/duckling-server start",
    "start:frontend": "pnpm --filter @lmes/duckling-frontend preview",
    "sync": "pnpm --filter @lmes/duckling-server sync",
    "sync:incremental": "pnpm --filter @lmes/duckling-server sync:incremental",
    "health": "pnpm --filter @lmes/duckling-server health",
    "status": "pnpm --filter @lmes/duckling-server status",
    "validate": "pnpm --filter @lmes/duckling-server validate",
    "clean": "pnpm --parallel --filter \"./packages/**\" exec rm -rf dist .nuxt .output node_modules",
    "typecheck": "pnpm --filter \"./packages/**\" exec tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb"
    ]
  }
}
