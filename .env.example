# ===========================================
# Duckling Environment Configuration
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DUCKDB_PATH=data/duckling.db
MYSQL_MAX_CONNECTIONS=5

# Sync Configuration
SYNC_INTERVAL_MINUTES=15
BATCH_SIZE=1000
MAX_RETRIES=3
ENABLE_INCREMENTAL_SYNC=true
WORKER_THREADS=3

# Query Governor
MAX_CONCURRENT_QUERIES=10
QUERY_TIMEOUT_MS=30000
QUERY_QUEUE_MAX=50
QUERY_HIGH_PRIORITY_BURST=3

# Health Checks
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=60000

# Logging
LOG_LEVEL=info

# Security & Authentication (REQUIRED)
# WARNING: These MUST be set to secure values before deploying to production!
# Generate secure values using: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-strong-password
DB_API_KEY=your-secure-api-key-here
SESSION_SECRET=generate-with-openssl-rand-hex-32
