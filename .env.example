# ===========================================
# Duckling Environment Configuration
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MYSQL_MAX_CONNECTIONS=5
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Replication backend
REPLICATION_BACKEND=duckling

# PeerDB (used when REPLICATION_BACKEND=peerdb)
PEERDB_ENABLED=false
PEERDB_API_URL=http://localhost:8113
PEERDB_UI_URL=http://localhost:3003
PEERDB_API_KEY=
PEERDB_SQL_HOST=localhost
PEERDB_SQL_PORT=9900
PEERDB_SQL_USER=peerdb
PEERDB_SQL_PASSWORD=peerdb
PEERDB_SQL_DATABASE=peerdb
PEERDB_SOURCE_PEER_PREFIX=mysql
PEERDB_TARGET_PEER_PREFIX=clickhouse
PEERDB_MIRROR_PREFIX=duckling
PEERDB_CLICKHOUSE_HOST=clickhouse
PEERDB_CLICKHOUSE_PORT=9000
PEERDB_CLICKHOUSE_TLS=false
PEERDB_FLOW_JOB_PREFIX=duckling
PEERDB_MYSQL_DISABLE_TLS=true
PEERDB_MYSQL_FLAVOR=mysql
PEERDB_MYSQL_REPLICATION_MECHANISM=auto

# RustFS / S3-compatible staging for PeerDB
RUSTFS_ENDPOINT=http://localhost:9002
RUSTFS_ACCESS_KEY=peerdb
RUSTFS_SECRET_KEY=peerdbsecret
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET=peerdb-stage
RUSTFS_USE_PATH_STYLE=true
AWS_ENDPOINT_URL_S3=http://localhost:9002
AWS_ACCESS_KEY_ID=peerdb
AWS_SECRET_ACCESS_KEY=peerdbsecret
AWS_REGION=us-east-1
PEERDB_S3_BUCKET=peerdb-stage

# PeerDB self-hosted infrastructure
PEERDB_CATALOG_POSTGRES_DB=peerdb
PEERDB_CATALOG_POSTGRES_USER=peerdb
PEERDB_CATALOG_POSTGRES_PASSWORD=peerdb
PEERDB_TEMPORAL_POSTGRES_DB=temporal
PEERDB_TEMPORAL_POSTGRES_USER=temporal
PEERDB_TEMPORAL_POSTGRES_PASSWORD=temporal

# Sync Configuration
SYNC_INTERVAL_MINUTES=15
BATCH_SIZE=1000
MAX_RETRIES=3
ENABLE_INCREMENTAL_SYNC=true

# Health Checks
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=60000

# Logging
LOG_LEVEL=info

# Security & Authentication (REQUIRED)
# WARNING: These MUST be set to secure values before deploying to production!
# Generate secure values using: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-strong-password
DB_API_KEY=your-secure-api-key-here
SESSION_SECRET=generate-with-openssl-rand-hex-32

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MODE=enforce
RATE_LIMIT_USE_SESSION_SCOPE=false
RATE_LIMIT_INCLUDE_DB_SCOPE=true
RATE_LIMIT_READ_MAX=120
RATE_LIMIT_QUERY_MAX=80
RATE_LIMIT_COST_QUERY=1
RATE_LIMIT_COST_WRITE=3
RATE_LIMIT_JWT_QUERY_MAX_IN_FLIGHT=6
RATE_LIMIT_APIKEY_QUERY_MAX_IN_FLIGHT=12
RATE_LIMIT_QUERY_INFLIGHT_TTL_MS=300000
