{
  "name": "@lmes/duckling-server",
  "version": "1.0.0",
  "description": "DuckDB server with MySQL replication using Sequential Appender architecture",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "dev:build": "tsc --watch",
    "sync": "node dist/cli.js sync",
    "sync:incremental": "node dist/cli.js sync-incremental",
    "health": "node dist/cli.js health",
    "status": "node dist/cli.js status",
    "validate": "node dist/cli.js validate"
  },
  "dependencies": {
    "@lmes/duckling-shared": "workspace:*",
    "@types/ws": "^8.18.1",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.6.0",
    "dotenv": "^16.3.1",
    "duckdb": "^1.3.2",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "duckdb",
      "@duckdb/node-api"
    ]
  }
}
