# Environment Configuration
NODE_ENV=development
PORT=3000

# Path Configuration
# DATA_PATH: Base data directory (auto-detected: /app/data in Docker, ./data in development)
# Uncomment to override:
# DATA_PATH=/app/data
# BACKUP_PATH=/app/data/backups

# DuckDB Configuration
DUCKDB_PATH=data/duckling.db
DUCKDB_MAX_CONNECTIONS=10

# MySQL Configuration
MYSQL_CONNECTION_STRING=mysql://username:password@host:port/database
MYSQL_MAX_CONNECTIONS=5

# Sync Configuration
SYNC_INTERVAL_MINUTES=15
BATCH_SIZE=1000
ENABLE_INCREMENTAL_SYNC=true
AUTO_START_SYNC=true
MAX_RETRIES=3
EXCLUDED_TABLES=

# Automation Configuration (Zero Manual Intervention)
# All automation features are ENABLED by default for hands-off operation
# Set to 'false' to disable individual features if needed
AUTO_CLEANUP=true
CLEANUP_INTERVAL_HOURS=24
RETENTION_DAYS=90
AUTO_BACKUP=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
AUTO_RESTART=true
MAX_RESTART_ATTEMPTS=3

# Monitoring Configuration
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=60000
LOG_LEVEL=info

# Security Configuration (REQUIRED FOR PRODUCTION)
# WARNING: These MUST be set to secure values before deploying to production!
# Generate secure values using: openssl rand -hex 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-strong-password
SESSION_SECRET=generate-with-openssl-rand-hex-32
DUCKLING_API_KEY=your-secure-api-key-here

# JWT Authentication Configuration
# JWT_SECRET: Secret key for signing JWT tokens (defaults to SESSION_SECRET if not set)
# JWT_EXPIRES_IN: Token expiration time (e.g., '1h', '7d', '30d')
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=1h

# Rate Limiting Configuration
# Rate limiting is ENABLED by default. Set to 'false' to disable.
RATE_LIMIT_ENABLED=true
# Per-category limits (max requests per window, anonymous tier)
# JWT users get 2x these limits, API key users get 5x
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_READ_WINDOW_MS=60000
RATE_LIMIT_READ_MAX=60
RATE_LIMIT_QUERY_WINDOW_MS=60000
RATE_LIMIT_QUERY_MAX=20
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=10
RATE_LIMIT_MONITORING_WINDOW_MS=60000
RATE_LIMIT_MONITORING_MAX=120
# Tier multipliers (applied to base limits above)
RATE_LIMIT_JWT_MULTIPLIER=2
RATE_LIMIT_APIKEY_MULTIPLIER=5
# Cleanup interval for stale rate limit entries
RATE_LIMIT_CLEANUP_INTERVAL_MS=60000
