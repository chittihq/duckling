{
  "name": "@lmes/duckling",
  "version": "0.0.4",
  "description": "High-performance WebSocket SDK for Duckling DuckDB Server",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "build:legacy": "tsc",
    "build:stub": "unbuild --stub",
    "dev": "unbuild --watch",
    "dev:legacy": "tsc --watch",
    "example:basic": "tsx examples/basic-query.ts",
    "example:parallel": "tsx examples/parallel-queries.ts",
    "example:connection-pool": "tsx examples/connection-pool.ts",
    "example:typed": "tsx examples/typed-queries.ts"
  },
  "keywords": [
    "duckdb",
    "websocket",
    "sdk",
    "client",
    "database"
  ],
  "author": "LMES Team",
  "license": "MIT",
  "dependencies": {
    "@lmes/duckling-shared": "workspace:*",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.8",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "unbuild": "^3.6.1"
  }
}
