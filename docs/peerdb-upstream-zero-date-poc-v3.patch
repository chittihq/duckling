@@ -1,10 +1,16 @@
 package connmysql
 
 import (
+	"log/slog"
 	"testing"
 	"time"
 
+	"github.com/go-mysql-org/go-mysql/mysql"
+	"github.com/go-mysql-org/go-mysql/replication"
 	"github.com/stretchr/testify/require"
+	"go.temporal.io/sdk/log"
+
+	"github.com/PeerDB-io/peerdb/flow/shared/types"
 )
 
 func TestProcessTime(t *testing.T) {
@@ -51,3 +57,95 @@ func TestProcessTime(t *testing.T) {
 		require.Equal(t, ts.out, tm)
 	}
 }
+
+func TestHasMysqlZeroDateComponent(t *testing.T) {
+	for _, tc := range []struct {
+		in  string
+		out bool
+	}{
+		{"0000-00-00", true},
+		{"0000-00-00 00:00:00", true},
+		{"0000-00-00 00:00:00.000000", true},
+		{"2024-00-15", true},          // zero month
+		{"2024-01-00", true},          // zero day
+		{"2024-00-00 10:30:00", true}, // zero month+day datetime
+		{"2024-01-15", false},
+		{"2024-01-15 10:30:00", false},
+		{"1970-01-01", false},
+		{"0000-01-01", false}, // zero year alone is representable in time.Time
+		{"1000-01-01", false},
+		{"", false},
+		{"short", false},
+	} {
+		require.Equal(t, tc.out, hasMysqlZeroDateComponent(tc.in), "input: %q", tc.in)
+	}
+}
+
+func TestZeroDateAsNullFieldValue(t *testing.T) {
+	dateFv := mysql.NewFieldValue(mysql.FieldValueTypeString, 0, []byte("0000-00-00"))
+	tsFv := mysql.NewFieldValue(mysql.FieldValueTypeString, 0, []byte("0000-00-00 00:00:00"))
+	partialFv := mysql.NewFieldValue(mysql.FieldValueTypeString, 0, []byte("2024-00-15"))
+	validFv := mysql.NewFieldValue(mysql.FieldValueTypeString, 0, []byte("2024-01-15"))
+
+	// Flag off: legacy epoch coercion is preserved.
+	qv, err := QValueFromMysqlFieldValue(types.QValueKindDate, mysql.MYSQL_TYPE_DATE, dateFv, false)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueDate{Val: time.Unix(0, 0)}, qv)
+
+	// Flag on: zero date becomes NULL.
+	qv, err = QValueFromMysqlFieldValue(types.QValueKindDate, mysql.MYSQL_TYPE_DATE, dateFv, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindDate), qv)
+
+	// Flag on: zero timestamp becomes NULL.
+	qv, err = QValueFromMysqlFieldValue(types.QValueKindTimestamp, mysql.MYSQL_TYPE_DATETIME, tsFv, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindTimestamp), qv)
+
+	// Flag on: partial-zero date becomes NULL instead of being rewritten to -01.
+	qv, err = QValueFromMysqlFieldValue(types.QValueKindDate, mysql.MYSQL_TYPE_DATE, partialFv, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindDate), qv)
+
+	// Flag on: valid dates are untouched.
+	qv, err = QValueFromMysqlFieldValue(types.QValueKindDate, mysql.MYSQL_TYPE_DATE, validFv, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueDate{Val: time.Date(2024, 1, 15, 0, 0, 0, 0, time.UTC)}, qv)
+}
+
+func TestZeroDateAsNullRowEvent(t *testing.T) {
+	logger := log.NewStructuredLogger(slog.Default())
+	var coercionReported bool
+	dateEv := &replication.TableMapEvent{ColumnType: []byte{mysql.MYSQL_TYPE_DATE}}
+	dtEv := &replication.TableMapEvent{ColumnType: []byte{mysql.MYSQL_TYPE_DATETIME}}
+
+	// Flag off: legacy epoch coercion is preserved.
+	qv, err := QValueFromMysqlRowEvent(dateEv, 0, nil, nil,
+		types.QValueKindDate, "0000-00-00", logger, &coercionReported, false)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueDate{Val: time.Unix(0, 0).UTC()}, qv)
+
+	// Flag on: zero DATE becomes NULL.
+	qv, err = QValueFromMysqlRowEvent(dateEv, 0, nil, nil,
+		types.QValueKindDate, "0000-00-00", logger, &coercionReported, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindDate), qv)
+
+	// Flag on: zero DATETIME (kind timestamp) becomes NULL.
+	qv, err = QValueFromMysqlRowEvent(dtEv, 0, nil, nil,
+		types.QValueKindTimestamp, "0000-00-00 00:00:00", logger, &coercionReported, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindTimestamp), qv)
+
+	// Flag on: DATE column altered to DATETIME (zero) becomes NULL.
+	qv, err = QValueFromMysqlRowEvent(dtEv, 0, nil, nil,
+		types.QValueKindDate, "0000-00-00 00:00:00", logger, &coercionReported, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueNull(types.QValueKindDate), qv)
+
+	// Flag on: valid values are untouched.
+	qv, err = QValueFromMysqlRowEvent(dateEv, 0, nil, nil,
+		types.QValueKindDate, "2024-01-15", logger, &coercionReported, true)
+	require.NoError(t, err)
+	require.Equal(t, types.QValueDate{Val: time.Date(2024, 1, 15, 0, 0, 0, 0, time.UTC)}, qv)
+}
