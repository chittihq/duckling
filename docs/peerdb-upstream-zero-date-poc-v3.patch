+// hasMysqlZeroDateComponent reports whether a MySQL date or datetime string
+// (`YYYY-MM-DD[ HH:MM:SS[.ffffff]]`) carries a zero month or day component.
+// Such values ('0000-00-00', '2024-00-15', '2024-01-00', ...) are storable in
+// MySQL but unrepresentable in time.Time, so they otherwise get coerced
+// (full-zero -> unix epoch, partial-zero -> '-00' rewritten to '-01').
+func hasMysqlZeroDateComponent(s string) bool {
+	return len(s) >= 10 && (s[5:7] == "00" || s[8:10] == "00")
