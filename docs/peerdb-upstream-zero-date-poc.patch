+func applyMySQLDestinationTypeOverride(tm *protos.TableMapping, columnName string, qkind types.QValueKind) types.QValueKind {
+	if tm == nil {
+		return qkind
+	}
+
+	for _, col := range tm.Columns {
+		if col == nil || col.SourceName != columnName {
+			continue
+		}
+
+		if col.DestinationType == "String" {
+			switch qkind {
+			case types.QValueKindDate,
+				types.QValueKindTimestamp,
+				types.QValueKindTimestampTZ,
+				types.QValueKindTime,
+				types.QValueKindTimeTZ:
+				return types.QValueKindString
+			}
+		}
+	}
+
+	return qkind
+}
